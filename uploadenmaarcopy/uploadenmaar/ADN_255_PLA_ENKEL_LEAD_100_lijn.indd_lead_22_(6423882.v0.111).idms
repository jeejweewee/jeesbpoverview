		<ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/TKST_0002 Tekst RR" FirstLineIndent="8.504576401634008" RuleAboveLineWeight="0.9993182072202972" RuleBelowLineWeight="0.9993182072202972" SplitColumnInsideGutter="6.0004511278195505" ParagraphBorderTopLeftCornerRadius="11.996359511350743" ParagraphBorderTopRightCornerRadius="11.996359511350743" ParagraphBorderBottomLeftCornerRadius="11.996359511350743" ParagraphBorderBottomRightCornerRadius="11.996359511350743" ParagraphShadingTopLeftCornerRadius="11.996359511350743" ParagraphShadingTopRightCornerRadius="11.996359511350743" ParagraphShadingBottomLeftCornerRadius="11.996359511350743" ParagraphShadingBottomRightCornerRadius="11.996359511350743" ParagraphBorderTopLineWeight="0.9996966259458953" ParagraphBorderBottomLineWeight="0.9996966259458953" ParagraphBorderLeftLineWeight="0.9996966259458953" ParagraphBorderRightLineWeight="0.9996966259458953">
