			"characters": 3500,
            "firstParagraphStyle": "TKSX_0003a Tekst RR Niet inspringen",
            "oversetLines": 1,
            "visibleArea": 84393.463,
            "requiredVisibleArea": 84393.463,
            "frames": [
                {
                    "id": 371088,
                    "geometricBounds": {
                        "x": 0,
